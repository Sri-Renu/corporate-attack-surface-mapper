# Copy this to .env and fill in your values
# Never commit .env to git

# ── Database ──────────────────────────────────────────────────
# LOCAL DEV: use localhost. Docker: uses internal service name (set automatically)
DATABASE_URL=postgresql+asyncpg://asm:asm@localhost:5432/asm

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Keys (all optional — demo mode without them) ──────────
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
GITHUB_TOKEN=          # raises GitHub rate limit 10 → 30 req/min

# ── App ───────────────────────────────────────────────────────
DEBUG=false
REPORT_DIR=/app/reports
MAX_CONCURRENT_SCANS=5